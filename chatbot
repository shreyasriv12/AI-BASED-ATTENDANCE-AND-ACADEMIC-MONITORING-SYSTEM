import tkinter as tk
from tkinter import *

# Simple responses (AI logic)
def chatbot_response(user_input):
    user_input = user_input.lower()

    if "hello" in user_input:
        return "Hello! How can I help you?"
    
    elif "attendance" in user_input:
        return "Attendance is marked using our AI system."
    
    elif "marks" in user_input:
        return "You can check marks in the dashboard."
    
    elif "notes" in user_input:
        return "Notes are available in the notes section."
    
    elif "erp" in user_input:
        return "This is an AI-based ERP system for students."
    
    elif "bye" in user_input:
        return "Goodbye! Have a nice day."
    
    else:
        return "Sorry, I didn't understand that."


# Send message
def send():
    msg = entry.get()
    chat.insert(END, "You: " + msg + "\n")

    response = chatbot_response(msg)
    chat.insert(END, "Bot: " + response + "\n\n")

    entry.delete(0, END)


# GUI
root = tk.Tk()
root.title("AI Chatbot")

chat = Text(root, height=20, width=50)
chat.pack()

entry = Entry(root, width=40)
entry.pack()

btn = Button(root, text="Send", command=send)
btn.pack()

root.mainloop()
