    id INT AUTO_INCREMENT PRIMARY KEY,
    title VARCHAR(100),
    content TEXT
);
app.post('/addNote', (req, res) => {
    const { title, content } = req.body;
    const sql = "INSERT INTO notes (title, content) VALUES (?, ?)";
    db.query(sql, [title, content], (err) => {
